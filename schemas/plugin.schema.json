{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ros2-ws-template/plugin.schema.json",
  "title": "ROS2 Package Interface Manifest",
  "description": "校验每个包的 plugin.yaml。plugin.yaml 只声明 ROS2 接口契约；包的元信息(name/version/maintainer)以 package.xml 为唯一来源。",
  "type": "object",
  "required": ["type"],
  "additionalProperties": false,

  "properties": {
    "type": {
      "type": "string",
      "enum": ["library", "node", "messages", "bringup"],
      "description": "包类型，决定哪些字段必填"
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "运行时依赖的其他本项目包（用于依赖图生成）"
    },
    "exposes": {
      "type": "object",
      "description": "库类型包的导出信息（type=library 时必填）"
    },
    "runtime": {
      "type": "object",
      "description": "节点类型包的运行时信息（type=node 时必填）"
    },
    "interfaces": {
      "type": "object",
      "description": "消息类型包的接口定义（type=messages 时必填）"
    },
    "subpackages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "集成包包含的子包（type=bringup 时必填）"
    }
  },

  "allOf": [
    {
      "description": "type=library: 暴露头文件目录",
      "if": { "properties": { "type": { "const": "library" } } },
      "then": {
        "required": ["exposes"],
        "properties": {
          "exposes": {
            "type": "object",
            "required": ["headers"],
            "additionalProperties": false,
            "properties": {
              "headers": {
                "type": "array",
                "items": { "type": "string" },
                "description": "暴露的头文件目录，如 [\"include/robot_common\"]"
              },
              "no_ros2_dependency": {
                "type": "boolean",
                "default": false,
                "description": "true 表示此库零 ROS2 依赖，纯 C++/STL"
              }
            }
          }
        }
      }
    },

    {
      "description": "type=node: ROS2 节点运行时契约",
      "if": { "properties": { "type": { "const": "node" } } },
      "then": {
        "required": ["runtime"],
        "properties": {
          "runtime": {
            "type": "object",
            "required": ["node"],
            "additionalProperties": false,
            "properties": {
              "node": {
                "type": "string",
                "description": "节点入口类，如 robot_hardware::controller::MainNode"
              },
              "lifecycle": { "type": "boolean", "default": false },
              "inputs": { "$ref": "#/definitions/topic_list" },
              "outputs": { "$ref": "#/definitions/topic_list" },
              "services_provided": { "$ref": "#/definitions/service_list" },
              "services_consumed": { "$ref": "#/definitions/service_list" },
              "actions_provided": { "$ref": "#/definitions/action_list" },
              "parameters": { "$ref": "#/definitions/parameter_list" },
              "tf_frames_provided": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["parent", "child"],
                  "additionalProperties": false,
                  "properties": {
                    "parent": { "type": "string" },
                    "child": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    {
      "description": "type=messages: msg/srv/action 接口声明",
      "if": { "properties": { "type": { "const": "messages" } } },
      "then": {
        "required": ["interfaces"],
        "properties": {
          "interfaces": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "msg": {
                "type": "array",
                "items": { "type": "string" },
                "description": "消息定义列表，如 [\"MotorState.msg\"]"
              },
              "srv": {
                "type": "array",
                "items": { "type": "string" }
              },
              "action": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },

    {
      "description": "type=bringup: 集成包包含的子包",
      "if": { "properties": { "type": { "const": "bringup" } } },
      "then": {
        "required": ["subpackages"],
        "properties": {
          "subpackages": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  ],

  "definitions": {
    "topic_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "type"],
        "additionalProperties": false,
        "properties": {
          "topic": {
            "type": "string",
            "pattern": "^~?(/[a-zA-Z0-9_]+)+$",
            "description": "接受 /foo/bar 或 ~/foo/bar（私有命名空间）"
          },
          "type": {
            "type": "string",
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*(/[a-zA-Z_][a-zA-Z0-9_]*){1,2}$",
            "description": "消息类型，如 std_msgs/msg/String 或 nav_msgs/Odometry"
          },
          "description": { "type": "string" },
          "qos": {
            "type": "string",
            "enum": ["best_effort", "reliable", "sensor", "services"]
          },
          "required": { "type": "boolean", "default": true }
        }
      }
    },
    "service_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "action_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "parameter_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "default", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "type": {
            "type": "string",
            "enum": ["int", "double", "string", "bool",
                     "int_array", "double_array", "string_array"]
          },
          "default": { "description": "默认值，必须与 type 字段类型匹配（见下方 allOf）" },
          "description": { "type": "string", "minLength": 5 },
          "unit": { "type": "string" },
          "range": { "type": "array", "minItems": 2, "maxItems": 2 }
        },
        "allOf": [
          { "if": { "properties": { "type": { "const": "int" } } },
            "then": { "properties": { "default": { "type": "integer" } } } },
          { "if": { "properties": { "type": { "const": "double" } } },
            "then": { "properties": { "default": { "type": "number" } } } },
          { "if": { "properties": { "type": { "const": "string" } } },
            "then": { "properties": { "default": { "type": "string" } } } },
          { "if": { "properties": { "type": { "const": "bool" } } },
            "then": { "properties": { "default": { "type": "boolean" } } } },
          { "if": { "properties": { "type": { "const": "int_array" } } },
            "then": { "properties": { "default": { "type": "array", "items": { "type": "integer" } } } } },
          { "if": { "properties": { "type": { "const": "double_array" } } },
            "then": { "properties": { "default": { "type": "array", "items": { "type": "number" } } } } },
          { "if": { "properties": { "type": { "const": "string_array" } } },
            "then": { "properties": { "default": { "type": "array", "items": { "type": "string" } } } } }
        ]
      }
    }
  }
}
